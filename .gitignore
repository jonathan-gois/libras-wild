# Vídeos e clipes
dataset/wild/*/clips/
dataset/wild/*/*.mp4
dataset/wild/*/*.pkl
!dataset/wild/*/meta.json
!dataset/wild/index.json
# Python
__pycache__/
*.pyc
env/
*.log
nohup.out

# LiBERT — artefatos grandes regeneráveis (rodar prepare_cache.py/pretrain.py/calibrate*.py)
LiBERT/cache/
LiBERT/checkpoints/*.pt
!LiBERT/checkpoints/.gitkeep

# Landmarks extraídos em lote — grandes, regeneráveis via src/extract_*.py
data/v_librasil_landmarks/*.pkl
!data/v_librasil_landmarks/index.csv
data/libras_ufop_landmarks/*/*.pkl
!data/libras_ufop_landmarks/index.csv

# Site de revisão — gerado por build_review_site.py, deploy real fica em docs/review/
LiBERT/review_site/
LiBERT/review_site.zip
